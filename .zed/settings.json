{
  "languages": {
    "JavaScript": {
      "language_servers": [
        "biome",
        "vtsls",
        "!eslint",
        "!typescript-language-server",
        "..."
      ]
    },
    "TypeScript": {
      "language_servers": [
        "biome",
        "vtsls",
        "!eslint",
        "!typescript-language-server",
        "..."
      ]
    },
    "TSX": {
      "language_servers": [
        "biome",
        "vtsls",
        "!eslint",
        "!typescript-language-server",
        "..."
      ]
    },
    "CSS": {
      "language_servers": [
        "tailwindcss-intellisense-css",
        "!vscode-css-language-server",
        "..."
      ]
    }
  },
  "formatter": {
    "language_server": { "name": "biome" }
  },
  "code_actions_on_format": {
    "source.fixAll.biome": true,
    "source.organizeImports.biome": true
  }
}
